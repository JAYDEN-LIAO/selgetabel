# 镜像版本标签（例如 0.1.0 或 latest）
IMAGE_VERSION=latest

# Web 服务端口（默认 8080）
WEB_PORT=8080

# ---- PostgreSQL ----
POSTGRES_USER=llm-excel
POSTGRES_PASSWORD=llm-excel
POSTGRES_DB=llm-excel

# ---- MinIO ----
# Docker 服务认证（MINIO_ROOT_USER/PASSWORD）
MINIO_ROOT_USER=llm-excel
MINIO_ROOT_PASSWORD=llm-excel

# API 访问 MinIO 的配置
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=llm-excel
MINIO_SECRET_KEY=llm-excel
MINIO_BUCKET=llm-excel
MINIO_PUBLIC_BASE=storage

# ---- API：JWT / 加密 ----
# 生成命令：openssl rand -hex 32
JWT_SECRET_KEY=
BCRYPT_ROUNDS=12

# ---- 日志级别 ----
LOG_LEVEL=INFO
